<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no">
    <title>DMData Quake Node Server</title>
    <link rel="stylesheet" href="/static/eew-item.css">
    <style>
      body {
        font-family: "Yu Gothic Medium", "Yu Gothic", "Hiragino Kaku Gothic ProN", "Noto Sans CJK JP", "Source Han Sans JP", "sans-serif";
        margin: 0;
        padding: 0;
      }
      h1 {
        background-color: #dde2fb;
        color: #6b6b6b;
        margin: 0;
        padding: 4px;
        text-align: center;
        font-size: 1rem;
      }
      /* ページの中心に表示 */
      .latest-eew {
        margin: 0 auto;
        max-width: 300px;
        padding: 8px;
      }
      .latest-eew-container {
        display: block;
        text-decoration: none;
        color: inherit;
      }

      /* トップ表示用にカスタム */
      .event-item {
        border: 1px solid #ccc;
        border-radius: 15px;
      }
      .event-item.event-warn::after {
        position: relative;
        left: 0;
      }

      /* 構文ハイライトが暴走しないようにする */
      a.a#a > a[a] + a[a~=a] {}
    </style>
  </head>
  <body>
    <main>
      <h1>DMData Quake Node Server</h1>
      <div class="latest-eew">
        <h2>最新の緊急地震速報</h2>
        <a class="latest-eew-container" href="/list/">
          <div class="event-item <%= classes.join(" ") %>">
            <div class="event-item-shindo"></div>
            <div class="event-item-content">
              <div class="event-item-header"><%= header %></div>
              <div class="event-item-body">
                <div class="event-item-epicenter"><%= epicenter %></div>
                <div class="event-item-metadata">
                  <div class="event-item-magnitude"><%= magnitude %></div>
                  <div class="event-item-depth"><%= depth %></div>
                </div>
              </div>
            </div>
            <div class="event-item-selected"></div>
          </div>
        </a>
      </div>
    </main>
    <script>

    </script>
  </body>
</html>
